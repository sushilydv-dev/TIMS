# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_NAME=tims
DB_USER=postgres
DB_PASSWORD=
JWT_SECRET_KEY=your-jwt-secret

# Comma-separated emails that always get ADMIN role on login/register
ADMIN_EMAIL=your-email@example.com

# Frontend base URL (activation links)
FRONTEND_URL=http://localhost:5173

# Sync schema on startup (alter tables). Set false in production if using migrations.
DB_SYNC_ALTER=true

# EmailJS
EMAILJS_SERVICE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_TEMPLATE_ID=
AUTH_TRAINER_HR_INVITE=template_wssigt3

# Razorpay keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
